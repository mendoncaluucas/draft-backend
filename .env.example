# Banco de dados (SQLite no desenvolvimento; PostgreSQL é o alvo de produção)
DATABASE_URL="file:./dev.db"

# NextAuth v5 (Auth.js) — segredo compartilhado entre front-end e back-end para
# assinar/validar o JWT. No NextAuth v5 a variável chama-se AUTH_SECRET.
AUTH_SECRET="substitua-por-uma-chave-segura-minimo-32-caracteres"

# URL do back-end (usada pelo front-end para montar as requisições)
NEXT_PUBLIC_API_URL="http://localhost:3001"
