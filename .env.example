# Banco de dados
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/draft"

# NextAuth — compartilhado entre front-end e back-end para validação do JWT
NEXTAUTH_SECRET="substitua-por-uma-chave-segura-minimo-32-caracteres"
NEXTAUTH_URL="http://localhost:3000"

# URL do back-end (usada pelo front-end para montar as requisições)
NEXT_PUBLIC_API_URL="http://localhost:3001"